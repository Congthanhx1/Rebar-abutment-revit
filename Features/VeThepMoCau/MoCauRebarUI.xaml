<Window x:Class="Vetheprevit.MoCau.MoCauRebarUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Công cụ Vẽ Mố Cầu - By CT" Height="740" Width="740" WindowStartupLocation="CenterScreen" Background="#F8FAFC" FontFamily="Segoe UI">
    
    <Window.Resources>
        <!-- Modern Global Styles -->
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <ContentPresenter Grid.Row="0" ContentSource="Header" RecognizesAccessKey="True" Margin="0,0,0,8" TextElement.FontWeight="Bold" TextElement.FontSize="14" TextElement.Foreground="#1E293B"/>
                            
                            <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12">
                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A" Opacity="0.05" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
        
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" Margin="0,0,4,0">
                            <Grid>
                                <Border Name="TopLine" Height="3" Background="#1E293B" VerticalAlignment="Top" Visibility="Hidden"/>
                                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="{TemplateBinding Padding}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="TopLine" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition x:Name="colPreview" Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Cột trái: Nhập liệu (Có TabControl) -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TabControl x:Name="tabMain"
                        Grid.Row="0"
                        SelectionChanged="TabMain_SelectionChanged">
                <!-- TAB 1: BỆ MỐ -->
                <TabItem Header="Bệ Mố" FontWeight="Bold">
                    <ScrollViewer x:Name="scrollBeMo" VerticalScrollBarVisibility="Auto" Padding="0,5,5,0">
                        <StackPanel>
                
                <!-- 1. Bệ Mố -->
                <GroupBox x:Name="grpBeMoGeo" Header="1. Chọn Mố Cầu" Margin="0,0,0,16" FontWeight="Bold">
                    <StackPanel Margin="0">
                        <TextBlock x:Name="txtSelectedAbutment" Text="Đang chọn: (Chưa có)" Foreground="#1E293B" FontWeight="SemiBold" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                        <Button x:Name="BtnPick" Content="CHỌN MỐ CẦU" Background="#377A70" Foreground="White" FontWeight="Bold" Padding="12,10" Click="BtnPick_Click" BorderThickness="0" ToolTip="Nhấn để chọn Mố trong mô hình"/>
                    </StackPanel>
                </GroupBox>

                <!-- 2. Lưới thép Đáy Bệ -->
                <GroupBox x:Name="grpBotRebar" Header="2. Lưới thép Đáy bệ" Margin="0,0,0,10" FontWeight="Bold">
                    <StackPanel Margin="0,5,0,0">
                        <!-- Thông số chung -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Hình dạng thép:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="Blue" FontWeight="Normal"/>
                            <ComboBox x:Name="cboShapeBot" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="25" DisplayMemberPath="Name" IsEditable="True"/>
                        </Grid>
                        
                        <Separator Margin="0,0,0,10" Background="LightGray"/>

                        <!-- Lớp thép trên (phương dọc X) -->
                        <CheckBox x:Name="chkDrawBotLong" Content="Thép trên / PDC (X)" IsChecked="True" FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,0,6" Checked="ChkDrawBotLong_CheckedChanged" Unchecked="ChkDrawBotLong_CheckedChanged"/>
                        <Grid x:Name="gridBotLong" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Đường kính thép:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <ComboBox x:Name="cboRebarBotLong" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="25" FontWeight="Normal" DisplayMemberPath="DisplayName" IsEditable="True"/>

                            <TextBlock Text="L ngàm:" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" FontWeight="Normal" Foreground="Blue" ToolTip="Chiều dài đoạn bẻ đứng của lớp thép rải dọc X"/>
                            <TextBox x:Name="txtBotMeshAnchorLong" Text="500" Grid.Row="1" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ ngang (Y):" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" FontWeight="Normal" ToolTip="Khoảng cách ghi kích thước từ mép bê tông đến biên thanh thép theo phương dọc cầu"/>
                            <TextBox x:Name="txtCoverBotLongX" Text="100" Grid.Row="2" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ dọc (X):" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" FontWeight="Normal" ToolTip="Khoảng cách ghi kích thước từ mép bê tông đến biên thanh thép theo phương ngang"/>
                            <TextBox x:Name="txtCoverBotLongY" Text="100" Grid.Row="3" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Cao độ đáy (Z):" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverBotZLong" Text="70" Grid.Row="4" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Thông số rải:" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,5">
                                <ComboBox x:Name="cboLayoutLBot" SelectedIndex="0" Margin="0,0,0,5" Height="25">
                                    <ComboBoxItem Content="1. Khoảng cách tối đa"/>
                                    <ComboBoxItem Content="2. Số lượng chia đều"/>
                                    <ComboBoxItem Content="3. Số lượng + Khoảng cách"/>
                                </ComboBox>
                                <WrapPanel Margin="0,5,0,0">
                                    <TextBlock Text="K.cách:" VerticalAlignment="Center" Width="45"/>
                                    <TextBox x:Name="txtSpaceLongBot" Text="150" Width="50" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="S.lượng:" VerticalAlignment="Center" Width="50"/>
                                    <TextBox x:Name="txtQtyLongBot" Text="15" Width="50" Height="25" VerticalContentAlignment="Center" IsEnabled="False"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,0,0,10" Background="LightGray"/>

                        <!-- Lớp thép dưới (phương ngang Y) -->
                        <CheckBox x:Name="chkDrawBotTrans" Content="Thép dưới / PNC (Y)" IsChecked="True" FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,0,6" Checked="ChkDrawBotTrans_CheckedChanged" Unchecked="ChkDrawBotTrans_CheckedChanged"/>
                        <Grid x:Name="gridBotTrans" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Đường kính thép:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <ComboBox x:Name="cboRebarBotTrans" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="25" FontWeight="Normal" DisplayMemberPath="DisplayName" IsEditable="True"/>

                            <TextBlock Text="L ngàm (mm):" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" FontWeight="Normal" Foreground="Blue" ToolTip="Chiều dài đoạn bẻ đứng của lớp thép rải ngang Y"/>
                            <TextBox x:Name="txtBotMeshAnchorTrans" Text="500" Grid.Row="1" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ ngang (Y):" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" FontWeight="Normal" ToolTip="Khoảng cách ghi kích thước từ mép bê tông đến biên thanh thép theo phương dọc cầu"/>
                            <TextBox x:Name="txtCoverBotTransX" Text="100" Grid.Row="2" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ dọc (X):" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" FontWeight="Normal" ToolTip="Khoảng cách ghi kích thước từ mép bê tông đến biên thanh thép theo phương ngang"/>
                            <TextBox x:Name="txtCoverBotTransY" Text="100" Grid.Row="3" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Cao độ đáy (Z):" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverBotZTrans" Text="50" Grid.Row="4" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Thông số rải:" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,5">
                                <ComboBox x:Name="cboLayoutTBot" SelectedIndex="0" Margin="0,0,0,5" Height="25">
                                    <ComboBoxItem Content="1. Khoảng cách tối đa"/>
                                    <ComboBoxItem Content="2. Số lượng chia đều"/>
                                    <ComboBoxItem Content="3. Số lượng + Khoảng cách"/>
                                </ComboBox>
                                <WrapPanel Margin="0,5,0,0">
                                    <TextBlock Text="K.cách:" VerticalAlignment="Center" Width="45"/>
                                    <TextBox x:Name="txtSpaceTransBot" Text="150" Width="50" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="S.lượng:" VerticalAlignment="Center" Width="50"/>
                                    <TextBox x:Name="txtQtyTransBot" Text="15" Width="50" Height="25" VerticalContentAlignment="Center" IsEnabled="False"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <CheckBox x:Name="chkSameTop" Content="Sử dụng chung thông số cho Thép Đỉnh bệ" IsChecked="True" Margin="5,0,0,10" Checked="ChkSameTop_CheckedChanged" Unchecked="ChkSameTop_CheckedChanged"/>

                <GroupBox x:Name="grpTop" Header="3. Lưới thép Đỉnh bệ" Margin="0,0,0,10" FontWeight="Bold" IsEnabled="False">
                    <StackPanel Margin="0,5,0,0">
                        <!-- Thông số chung -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Hình dạng thép (Shape):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="Blue" FontWeight="Normal"/>
                            <ComboBox x:Name="cboShapeTop" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="25" DisplayMemberPath="Name" IsEditable="True"/>
                        </Grid>
                        
                        <Separator Margin="0,0,0,10" Background="LightGray"/>

                        <!-- Lớp thép trên (phương dọc X) -->
                        <CheckBox x:Name="chkDrawTopLong" Content="Lớp thép trên / Rải dọc (X)" IsChecked="True" FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,0,6" Checked="ChkDrawTopLong_CheckedChanged" Unchecked="ChkDrawTopLong_CheckedChanged"/>
                        <Grid x:Name="gridTopLong" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Đường kính thép:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <ComboBox x:Name="cboRebarTopLong" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="25" FontWeight="Normal" DisplayMemberPath="DisplayName" IsEditable="True"/>

                            <TextBlock Text="L ngàm (mm):" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" FontWeight="Normal" Foreground="Blue" ToolTip="Chiều dài đoạn bẻ đứng của lớp thép đỉnh rải dọc X"/>
                            <TextBox x:Name="txtTopMeshAnchorLong" Text="500" Grid.Row="1" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ dọc (X):" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverTopLongX" Text="100" Grid.Row="2" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ ngang (Y):" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverTopLongY" Text="100" Grid.Row="3" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Cao độ đỉnh (Z):" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverTopZLong" Text="70" Grid.Row="4" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Thông số rải:" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,5">
                                <ComboBox x:Name="cboLayoutLTop" SelectedIndex="0" Margin="0,0,0,5" Height="25">
                                    <ComboBoxItem Content="1. Khoảng cách tối đa"/>
                                    <ComboBoxItem Content="2. Số lượng chia đều"/>
                                    <ComboBoxItem Content="3. Số lượng + Khoảng cách"/>
                                </ComboBox>
                                <WrapPanel Margin="0,5,0,0">
                                    <TextBlock Text="K.cách:" VerticalAlignment="Center" Width="45"/>
                                    <TextBox x:Name="txtSpaceLongTop" Text="150" Width="50" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="S.lượng:" VerticalAlignment="Center" Width="50"/>
                                    <TextBox x:Name="txtQtyLongTop" Text="15" Width="50" Height="25" VerticalContentAlignment="Center" IsEnabled="False"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,0,0,10" Background="LightGray"/>

                        <!-- Lớp thép dưới (phương ngang Y) -->
                        <CheckBox x:Name="chkDrawTopTrans" Content="Lớp thép dưới / Rải ngang (Y)" IsChecked="True" FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,0,6" Checked="ChkDrawTopTrans_CheckedChanged" Unchecked="ChkDrawTopTrans_CheckedChanged"/>
                        <Grid x:Name="gridTopTrans" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Đường kính thép:" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <ComboBox x:Name="cboRebarTopTrans" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="25" FontWeight="Normal" DisplayMemberPath="DisplayName" IsEditable="True"/>

                            <TextBlock Text="L ngàm (mm):" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" FontWeight="Normal" Foreground="Blue" ToolTip="Chiều dài đoạn bẻ đứng của lớp thép đỉnh rải ngang Y"/>
                            <TextBox x:Name="txtTopMeshAnchorTrans" Text="500" Grid.Row="1" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ dọc (X):" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverTopTransX" Text="100" Grid.Row="2" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Lớp bảo vệ ngang (Y):" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverTopTransY" Text="100" Grid.Row="3" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Cao độ đỉnh (Z):" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" FontWeight="Normal"/>
                            <TextBox x:Name="txtCoverTopZTrans" Text="50" Grid.Row="4" Grid.Column="1" Margin="0,5" Height="25" VerticalContentAlignment="Center" FontWeight="Normal"/>

                            <TextBlock Text="Thông số rải:" VerticalAlignment="Center" Grid.Row="5" Grid.Column="0" FontWeight="Normal" Foreground="Blue"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,5">
                                <ComboBox x:Name="cboLayoutTTop" SelectedIndex="0" Margin="0,0,0,5" Height="25">
                                    <ComboBoxItem Content="1. Khoảng cách tối đa"/>
                                    <ComboBoxItem Content="2. Số lượng chia đều"/>
                                    <ComboBoxItem Content="3. Số lượng + Khoảng cách"/>
                                </ComboBox>
                                <WrapPanel Margin="0,5,0,0">
                                    <TextBlock Text="K.cách:" VerticalAlignment="Center" Width="45"/>
                                    <TextBox x:Name="txtSpaceTransTop" Text="150" Width="50" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="S.lượng:" VerticalAlignment="Center" Width="50"/>
                                    <TextBox x:Name="txtQtyTransTop" Text="15" Width="50" Height="25" VerticalContentAlignment="Center" IsEnabled="False"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- 4. Thép hông đứng -->
                <GroupBox x:Name="grpVertSide" Header="4. Thép đứng (z)" Margin="0,0,0,10" FontWeight="Bold">
                    <StackPanel Margin="0,5,0,0">
                        <!-- Thông số chung -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Hình dạng thép :" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" Foreground="Blue" FontWeight="Normal"/>
                            <ComboBox x:Name="cboShapeVertSide" Grid.Row="0" Grid.Column="1" Margin="0,5" Height="25" DisplayMemberPath="Name" IsEditable="True"/>
                            
                            <TextBlock Text="Lớp bảo vệ (XY):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontWeight="Normal"/>
