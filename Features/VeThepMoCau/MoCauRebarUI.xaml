                    </ScrollViewer>
                </TabItem>

                <TabItem Header="MỤC LỤC">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10,10,10,10" TextElement.FontWeight="Normal">
                            <StackPanel.Resources>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FFFFFF"/>
                                    <Setter Property="Foreground" Value="#334155"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="10,6"/>
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F1F5F9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#E2E8F0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Resources>
                            <StackPanel x:Name="navBeMo">
                                <Border Background="#F8FAFC" Padding="4" CornerRadius="4" Margin="0,0,0,8">
                                    <TextBlock Text="--- TAB BỆ MỐ ---" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center" FontSize="11"/>
                                </Border>
                                <Button Content="1. Chọn Mố Cầu" Click="Nav_BeMoGeo_Click"/>
                                <Button Content="2. Thép Đáy bệ" Click="Nav_BotRebar_Click"/>
                                <Button Content="3. Thép Đỉnh bệ" Click="Nav_TopRebar_Click"/>
                                <Button Content="4. Thép đứng" Click="Nav_VertSide_Click"/>
                                <Button Content="5. Thép chống nở hông" Click="Nav_AntiBurst_Click"/>
                                <Button Content="6. Thép chờ thân mố" Click="Nav_Dowel_Click"/>
                                <Button Content="7. Thép dọc hông" Click="Nav_HorizSide_Click" Margin="0,0,0,16"/>
                            </StackPanel>

                            <StackPanel x:Name="navThanMo">
                                <Border Background="#F8FAFC" Padding="4" CornerRadius="4" Margin="0,0,0,8">
                                    <TextBlock Text="--- TAB THÂN MỐ ---" FontWeight="Bold" Foreground="#64748B" HorizontalAlignment="Center" FontSize="11"/>
                                </Border>
                                <Button Content="1. Thép đứng Trước" Click="Nav_StemVertFront_Click"/>
                                <Button Content="2. Thép đứng Sau" Click="Nav_StemVertBack_Click"/>
                                <Button Content="3. Thép ngang" Click="Nav_StemHoriz_Click"/>
                                <Button Content="4. Thép đai" Click="Nav_StemTie_Click" Margin="0,0,0,16"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
            </Grid>
        </Border>

        <Border x:Name="borderPreview" Grid.Column="2"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                Background="#FFFFFF"
                CornerRadius="8"
                Margin="16,0,0,0"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtPreviewTitle"
                           Grid.Row="0"
                           Text="PREVIEW 2D"
                           Foreground="#1E293B"
                           FontWeight="Bold"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,10"/>

                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,8">
                    <Button x:Name="btnPreviewPlan"
                            Content="Mặt bằng"
                            Tag="Plan"
                            Padding="6,6"
                            FontSize="11"
                            Click="PreviewView_Click"/>
                    <Button x:Name="btnPreviewFront"
                            Content="Chiếu đứng"
                            Tag="Front"
                            Padding="6,6"
                            FontSize="11"
                            Click="PreviewView_Click"/>
                    <Button x:Name="btnPreviewSide"
                            Content="Chiếu cạnh"
                            Tag="Side"
                            Padding="6,6"
                            FontSize="11"
                            Click="PreviewView_Click"/>
                </UniformGrid>

                <Border Grid.Row="2"
                        Background="#F8FAFC"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1"
                        CornerRadius="6"
                        ClipToBounds="True">
                    <Canvas x:Name="previewCanvas"
                            Background="Transparent"
                            SizeChanged="PreviewCanvas_SizeChanged"
                            PreviewMouseWheel="PreviewCanvas_MouseWheel"
                            MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"/>
                </Border>

                <TextBlock x:Name="txtPreviewHint"
                           Grid.Row="3"
                           Text="Cuộn chuột để zoom, nhấp đúp để về 100%."
                           Foreground="#64748B"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="4,10,4,2"/>
            </Grid>
        </Border>
    </Grid>
</Window>

