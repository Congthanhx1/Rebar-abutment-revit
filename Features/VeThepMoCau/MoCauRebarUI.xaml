                            </Border>
                            <CheckBox x:Name="chkDrawStemVertFront" Content="Thép đứng trước" IsChecked="True" Margin="0,0,0,6"/>
                            <CheckBox x:Name="chkDrawStemVertBack" Content="Thép đứng sau" IsChecked="True" Margin="0,0,0,6"/>
                            <CheckBox x:Name="chkDrawStemHoriz" Content="Thép ngang" IsChecked="True" Margin="0,0,0,6"/>
                            <CheckBox x:Name="chkDrawStemTie" Content="Thép đai" IsChecked="True" Margin="0,0,0,6"/>
